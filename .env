# Environment configuration
# Local development values are active below.
# Example values are kept here as comments so this single file can also serve as reference.

# Database
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=scraper_db
# Example: MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>/<db>?retryWrites=true&w=majority
# Optional fallback if the main URI is unavailable
# MONGODB_FALLBACK_URI=mongodb://localhost:27017

# Authentication
JWT_SECRET_KEY=change-this-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
# Example: JWT_SECRET_KEY=replace-with-a-long-random-secret

# API
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
# Example: ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173