# Environment Variables
# Copy this file to .env and fill in your actual values

# MongoDB Atlas Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/scraper_db?retryWrites=true&w=majority
MONGODB_DB_NAME=scraper_db
# Optional fallback if the primary MongoDB URI cannot be reached
# MONGODB_FALLBACK_URI=mongodb://localhost:27017

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-here-change-this-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000

# Security
BCRYPT_ROUNDS=12

# CORS Settings (comma-separated URLs)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Development/Production
ENVIRONMENT=development
DEBUG=true